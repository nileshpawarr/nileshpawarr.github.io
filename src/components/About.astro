---
import SectionReveal from '~/components/SectionReveal.astro';
import { profile } from '~/data/profile';

const highlights = [
  { value: '12+', label: 'years shipping production frontend' },
  { value: '4', label: 'frameworks across enterprise and product' },
  { value: 'MFE', label: 'microfrontend architect (Angular 15)' },
  { value: 'AI', label: 'Claude + MCP delivery pipelines' },
];
---

<section
  id="about"
  aria-labelledby="about-heading"
  class="scroll-mt-20 border-t border-border px-6 py-24 md:px-16 md:py-32"
>
  <div class="mx-auto max-w-container">
    <SectionReveal>
      <p class="mb-6 text-meta uppercase tracking-label text-text-faint">About</p>
      <h2
        id="about-heading"
        class="mb-8 max-w-content text-xl font-medium tracking-head text-text md:text-2xl"
      >
        Senior frontend-focused full stack engineer, building quietly opinionated software in
        Berlin.
      </h2>
      <div class="max-w-content space-y-5 text-lg text-text-muted">
        <p>{profile.summary}</p>
      </div>

      <ul class="mt-12 grid max-w-container grid-cols-2 gap-x-8 gap-y-6 md:grid-cols-4">
        {
          highlights.map((h) => (
            <li class="border-l border-border pl-4">
              <p class="text-2xl font-medium leading-none text-text">{h.value}</p>
              <p class="mt-2 text-sm leading-snug text-text-muted">{h.label}</p>
            </li>
          ))
        }
      </ul>
    </SectionReveal>
  </div>
</section>
