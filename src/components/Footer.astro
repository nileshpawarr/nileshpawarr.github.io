---
const buildYear = new Date().getFullYear();
---

<footer class="border-t border-border px-6 py-12 md:px-16">
  <div class="mx-auto flex max-w-container items-baseline justify-between">
    <p class="text-meta uppercase tracking-label text-text-faint">
      NP · {buildYear}
    </p>
    <a
      href="https://github.com/nileshpawarr/nileshpawarr.github.io"
      target="_blank"
      rel="noopener noreferrer"
      class="text-meta uppercase tracking-label text-text-faint transition-colors duration-fast ease-snappy hover:text-accent"
    >
      Source ↗
    </a>
  </div>
</footer>
