---
import SectionReveal from '~/components/SectionReveal.astro';
import { experience } from '~/data/experience';
---

<section
  id="experience"
  aria-labelledby="experience-heading"
  class="scroll-mt-20 border-t border-border px-6 py-24 md:px-16 md:py-32"
>
  <div class="mx-auto max-w-container">
    <SectionReveal>
      <p class="mb-6 text-meta uppercase tracking-label text-text-faint">Experience</p>
      <h2
        id="experience-heading"
        class="mb-10 max-w-content text-xl font-medium tracking-head text-text md:text-2xl"
      >
        Twelve years across enterprise consultancies and product-led startups.
      </h2>

      <ol class="divide-y divide-border border-y border-border">
        {
          experience.map((e, i) => {
            const hasHighlights = e.highlights.length > 0;
            const id = `xp-${i}`;
            return (
              <li class="group/xp">
                <details class:list={['xp-entry', !hasHighlights && 'no-toggle']} id={id}>
                  <summary class="grid cursor-pointer list-none grid-cols-1 items-baseline gap-x-6 gap-y-1 py-6 transition-colors duration-fast ease-snappy hover:text-accent md:grid-cols-[1fr_auto_auto]">
                    <div>
                      <p class="text-base font-medium text-text">{e.company}</p>
                      <p class="text-sm text-text-muted">{e.role}</p>
                    </div>
                    <p class="text-sm text-text-faint">{e.location}</p>
                    <p class="font-mono text-sm text-text-faint">
                      {e.start} — {e.end ?? 'Present'}
                    </p>
                  </summary>

                  {hasHighlights && (
                    <div class="xp-content max-w-content pb-6 pl-0 md:pl-0">
                      <ul class="space-y-2 text-base text-text-muted">
                        {e.highlights.map((h) => (
                          <li class="flex gap-3">
                            <span
                              aria-hidden="true"
                              class="mt-2 inline-block h-px w-3 flex-none bg-accent"
                            />
                            <span>{h}</span>
                          </li>
                        ))}
                      </ul>
                      {e.stack && e.stack.length > 0 && (
                        <ul class="mt-4 flex flex-wrap gap-2">
                          {e.stack.map((s) => (
                            <li class="rounded-full border border-border px-2.5 py-1 text-meta uppercase tracking-label text-text-faint">
                              {s}
                            </li>
                          ))}
                        </ul>
                      )}
                    </div>
                  )}
                </details>
              </li>
            );
          })
        }
      </ol>
    </SectionReveal>
  </div>
</section>

<style>
  /* Entries without highlights don't toggle */
  details.no-toggle summary {
    cursor: default;
    pointer-events: none;
  }
  details.no-toggle summary:hover {
    color: inherit;
  }

  /* Smooth height animation using grid-template-rows trick.
     details element's content is unhidden via JS below; CSS animates max-height. */
  details.xp-entry .xp-content {
    overflow: hidden;
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--dur-base) var(--ease-standard);
  }
  details.xp-entry[open] .xp-content {
    grid-template-rows: 1fr;
  }
  details.xp-entry .xp-content > * {
    min-height: 0;
  }

  /* Hide native disclosure triangle */
  details.xp-entry > summary::-webkit-details-marker {
    display: none;
  }
  details.xp-entry > summary::marker {
    display: none;
  }
</style>
