---
import SectionReveal from '~/components/SectionReveal.astro';
import { projects, allProjectsUrl } from '~/data/projects';
---

<section
  id="projects"
  aria-labelledby="projects-heading"
  class="scroll-mt-20 border-t border-border px-6 py-24 md:px-16 md:py-32"
>
  <div class="mx-auto max-w-container">
    <SectionReveal>
      <p class="mb-6 text-meta uppercase tracking-label text-text-faint">Projects</p>
      <h2
        id="projects-heading"
        class="mb-10 max-w-content text-xl font-medium tracking-head text-text md:text-2xl"
      >
        Selected open-source.
      </h2>

      <ul class="grid gap-6 md:grid-cols-2">
        {
          projects.map((p) => (
            <li>
              <a
                href={p.repoUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="project-card block h-full rounded-lg border border-border p-6 transition-[transform,border-color,box-shadow] duration-base ease-standard hover:-translate-y-px hover:border-accent hover:shadow-[0_8px_24px_-12px_var(--accent-soft)]"
              >
                <div class="flex items-baseline justify-between gap-4">
                  <h3 class="text-lg font-medium text-text">{p.name}</h3>
                  <span
                    aria-hidden="true"
                    class="text-accent transition-transform duration-fast ease-snappy group-hover:translate-x-1"
                  >
                    ↗
                  </span>
                </div>
                <p class="mt-3 text-base text-text-muted">{p.description}</p>
                <ul class="mt-5 flex flex-wrap gap-2">
                  {p.stack.map((s) => (
                    <li class="rounded-full border border-border px-2.5 py-1 text-meta uppercase tracking-label text-text-faint">
                      {s}
                    </li>
                  ))}
                </ul>
              </a>
            </li>
          ))
        }
      </ul>

      <p class="mt-10 text-sm">
        <a
          href={allProjectsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-baseline gap-1 border-b border-border pb-0.5 text-text-muted transition-colors duration-fast ease-snappy hover:border-accent hover:text-accent"
        >
          View all repositories on GitHub
          <span aria-hidden="true" class="text-accent">↗</span>
        </a>
      </p>
    </SectionReveal>
  </div>
</section>
